// Interface settings content (#23 follow-up).
//
// Embedded panel (not a window): it lives inside AppWindow's modal overlay, so
// the settings can't be dragged out of the parent and block input while open —
// while keeping the clean, minimal "label-left · control-right" design.
// Typography is fixed (literal px in the chrome) so it stays compact regardless
// of the global UI scale; only the font-preview reflects the real terminal size.

import { Theme } from "theme.slint";
import { ComboBox, Slider, ScrollView } from "std-widgets.slint";
import { LabeledInput, PrimaryButton, GhostButton } from "widgets.slint";

export struct OutputRuleItem {
    pattern: string,
    regex: bool,
    case-sensitive: bool,
    whole-line: bool,
    color: string,
    enabled: bool,
}

// One left-nav row (icon + label).
component NavItem inherits Rectangle {
    in property <string> icon;
    in property <string> label;
    in property <bool> active;
    callback clicked();
    height: 30px;
    border-radius: 6px;
    background: root.active ? Theme.bg-active : (ta.has-hover ? Theme.bg-hover : transparent);
    ta := TouchArea {
        mouse-cursor: pointer;
        clicked => { root.clicked(); }
    }
    HorizontalLayout {
        padding-left: 10px;
        spacing: 9px;
        Text { text: root.icon; font-family: "Material Icons";
               color: root.active ? Theme.text-primary : Theme.text-secondary;
               font-size: 15px * Theme.panel-font; vertical-alignment: center; }
        Text { text: root.label;
               color: root.active ? Theme.text-primary : Theme.text-secondary;
               font-size: 13px * Theme.panel-font; vertical-alignment: center; horizontal-stretch: 1; }
    }
}

// Small muted group heading (字体 / 预览 / SFTP …).
component SectionHeader inherits Text {
    font-size: 11px * Theme.panel-font;
    font-weight: 700;
    color: Theme.text-muted;
    vertical-alignment: center;
}

// A settings row: label (+ optional description) on the left, a control slot on
// the right via @children. Right-aligned and vertically centered.
component SettingRow inherits Rectangle {
    in property <string> label;
    in property <string> desc;
    in property <bool> show-divider: true;
    VerticalLayout {
        HorizontalLayout {
            spacing: 14px;
            padding-top: 9px;
            padding-bottom: 9px;
            VerticalLayout {
                horizontal-stretch: 1;
                alignment: center;
                spacing: 3px;
                Text { text: root.label; font-size: 13px * Theme.panel-font; color: Theme.text-primary; }
                if root.desc != "" : Text { text: root.desc; font-size: 11px * Theme.panel-font;
                       color: Theme.text-muted; wrap: word-wrap; }
            }
            VerticalLayout {
                alignment: center;
                @children
            }
        }
        if root.show-divider : Rectangle { height: 1px; background: Theme.border-subtle; }
    }
}

// iOS-style toggle switch. Display-only `on` (driven by the parent); a tap emits
// the intended new value so the parent owns the state (avoids Slint's
// binding-break-on-self-assign gotcha).
component Switch inherits Rectangle {
    in property <bool> on;
    callback toggled(bool);
    width: 38px;
    height: 22px;
    border-radius: 11px;
    background: root.on ? Theme.accent : Theme.bg-active;
    animate background { duration: 120ms; }
    Rectangle {
        width: 16px;
        height: 16px;
        border-radius: 8px;
        y: 3px;
        x: root.on ? parent.width - self.width - 3px : 3px;
        background: white;
        animate x { duration: 120ms; easing: ease-out; }
    }
    TouchArea {
        mouse-cursor: pointer;
        clicked => { root.toggled(!root.on); }
    }
}

// [- value +] stepper. Display-only `value`; emits the clamped new value.
component Stepper inherits Rectangle {
    in property <int> value;
    in property <int> minimum: 0;
    in property <int> maximum: 100;
    in property <int> step: 1;
    in property <string> unit;
    callback changed(int);
    width: 112px;
    height: 26px;
    border-radius: 6px;
    background: Theme.bg-elevated;
    border-width: 1px;
    border-color: Theme.border-subtle;
    clip: true;
    HorizontalLayout {
        Rectangle {
            width: 30px;
            background: minus-ta.has-hover ? Theme.bg-hover : transparent;
            minus-ta := TouchArea {
                mouse-cursor: pointer;
                clicked => { root.changed(max(root.minimum, root.value - root.step)); }
            }
            Text { text: "\u{E15B}"; font-family: "Material Icons"; font-size: 14px * Theme.panel-font;
                   color: Theme.text-secondary; horizontal-alignment: center; vertical-alignment: center; }
        }
        Rectangle { width: 1px; background: Theme.border-subtle; }
        Text { text: root.value + root.unit; horizontal-stretch: 1;
               font-size: 12px * Theme.panel-font; color: Theme.text-primary;
               horizontal-alignment: center; vertical-alignment: center; }
        Rectangle { width: 1px; background: Theme.border-subtle; }
        Rectangle {
            width: 30px;
            background: plus-ta.has-hover ? Theme.bg-hover : transparent;
            plus-ta := TouchArea {
                mouse-cursor: pointer;
                clicked => { root.changed(min(root.maximum, root.value + root.step)); }
            }
            Text { text: "\u{E145}"; font-family: "Material Icons"; font-size: 14px * Theme.panel-font;
                   color: Theme.text-secondary; horizontal-alignment: center; vertical-alignment: center; }
        }
    }
}

// Compact cursor-shape choice with a live visual sample (#275).
component CursorStyleButton inherits Rectangle {
    in property <string> label;
    in property <string> cursor-kind;
    in property <bool> selected;
    callback clicked();
    width: 74px;
    height: 30px;
    border-radius: 6px;
    border-width: 1px;
    border-color: root.selected ? Theme.accent : Theme.border-subtle;
    background: root.selected ? Theme.bg-active : (cursor-ta.has-hover ? Theme.bg-hover : Theme.bg-elevated);
    cursor-ta := TouchArea {
        mouse-cursor: pointer;
        clicked => { root.clicked(); }
    }
    HorizontalLayout {
        padding-left: 7px;
        padding-right: 7px;
        spacing: 6px;
        alignment: center;
        Rectangle {
            width: 14px;
            height: 100%;
            background: transparent;
            Rectangle {
                y: (parent.height - self.height) / 2;
                width: 14px;
                height: 18px;
                background: Theme.term-bg;
                Rectangle {
                    x: 2px;
                    y: root.cursor-kind == "underline" ? parent.height - 3px : 2px;
                    width: root.cursor-kind == "bar" ? 2px : 10px;
                    height: root.cursor-kind == "underline" ? 2px : 14px;
                    background: Theme.term-fg;
                }
            }
        }
        Text {
            text: root.label;
            color: root.selected ? Theme.text-primary : Theme.text-secondary;
            font-size: 11px * Theme.panel-font;
            vertical-alignment: center;
        }
    }
}

component CursorPaletteSwatch inherits Rectangle {
    in property <string> hex;
    in property <color> swatch-color;
    in property <bool> selected;
    callback chosen(string);
    width: 26px;
    height: 26px;
    border-radius: 5px;
    border-width: root.selected ? 2px : 1px;
    border-color: root.selected ? Theme.accent : Theme.border-strong;
    background: root.swatch-color;
    swatch-ta := TouchArea {
        mouse-cursor: pointer;
        clicked => { root.chosen(root.hex); }
    }
}

// Hex RGB editor with a live swatch. Incomplete/invalid input remains editable
// but is marked red and is not applied or persisted.
component CursorColorInput inherits Rectangle {
    in-out property <string> value;
    in property <color> preview-color;
    property <bool> valid: true;
    callback apply-color(string) -> bool;
    width: 160px;
    height: 30px;
    border-radius: 6px;
    border-width: 1px;
    border-color: root.valid ? Theme.border-subtle : #e05252;
    background: Theme.bg-elevated;
    Rectangle {
        x: 7px;
        y: 6px;
        width: 18px;
        height: 18px;
        border-radius: 4px;
        border-width: 1px;
        border-color: Theme.border-strong;
        background: root.preview-color;
        color-button := TouchArea {
            mouse-cursor: pointer;
            clicked => { color-picker.show(); }
        }
    }
    color-input := TextInput {
        x: 34px;
        width: parent.width - 41px;
        height: parent.height;
        text <=> root.value;
        color: Theme.text-primary;
        font-family: Theme.term-font-family;
        font-size: 12px * Theme.panel-font;
        vertical-alignment: center;
        single-line: true;
        changed text => { root.valid = root.apply-color(self.text); }
    }
    color-picker := PopupWindow {
        x: parent.width - self.width;
        y: parent.height + 4px;
        width: 210px;
        height: 160px;
        Rectangle {
            background: Theme.bg-panel;
            border-radius: 8px;
            border-width: 1px;
            border-color: Theme.border-strong;
            drop-shadow-blur: 12px;
            drop-shadow-color: #00000060;
            VerticalLayout {
                padding: 10px;
                spacing: 7px;
                Text {
                    text: root.value;
                    color: Theme.text-secondary;
                    font-family: Theme.term-font-family;
                    font-size: 11px * Theme.panel-font;
                    vertical-alignment: center;
                }
                HorizontalLayout {
                    spacing: 6px;
                    CursorPaletteSwatch { hex: "#D4D4D4"; swatch-color: #D4D4D4; selected: root.value == self.hex; chosen(v) => { if root.apply-color(v) { root.value = v; root.valid = true; color-picker.close(); } } }
                    CursorPaletteSwatch { hex: "#FFFFFF"; swatch-color: #FFFFFF; selected: root.value == self.hex; chosen(v) => { if root.apply-color(v) { root.value = v; root.valid = true; color-picker.close(); } } }
                    CursorPaletteSwatch { hex: "#FF5252"; swatch-color: #FF5252; selected: root.value == self.hex; chosen(v) => { if root.apply-color(v) { root.value = v; root.valid = true; color-picker.close(); } } }
                    CursorPaletteSwatch { hex: "#FF9800"; swatch-color: #FF9800; selected: root.value == self.hex; chosen(v) => { if root.apply-color(v) { root.value = v; root.valid = true; color-picker.close(); } } }
                    CursorPaletteSwatch { hex: "#FFD740"; swatch-color: #FFD740; selected: root.value == self.hex; chosen(v) => { if root.apply-color(v) { root.value = v; root.valid = true; color-picker.close(); } } }
                    CursorPaletteSwatch { hex: "#69F0AE"; swatch-color: #69F0AE; selected: root.value == self.hex; chosen(v) => { if root.apply-color(v) { root.value = v; root.valid = true; color-picker.close(); } } }
                }
                HorizontalLayout {
                    spacing: 6px;
                    CursorPaletteSwatch { hex: "#00E676"; swatch-color: #00E676; selected: root.value == self.hex; chosen(v) => { if root.apply-color(v) { root.value = v; root.valid = true; color-picker.close(); } } }
                    CursorPaletteSwatch { hex: "#00E5FF"; swatch-color: #00E5FF; selected: root.value == self.hex; chosen(v) => { if root.apply-color(v) { root.value = v; root.valid = true; color-picker.close(); } } }
                    CursorPaletteSwatch { hex: "#40C4FF"; swatch-color: #40C4FF; selected: root.value == self.hex; chosen(v) => { if root.apply-color(v) { root.value = v; root.valid = true; color-picker.close(); } } }
                    CursorPaletteSwatch { hex: "#448AFF"; swatch-color: #448AFF; selected: root.value == self.hex; chosen(v) => { if root.apply-color(v) { root.value = v; root.valid = true; color-picker.close(); } } }
                    CursorPaletteSwatch { hex: "#7C4DFF"; swatch-color: #7C4DFF; selected: root.value == self.hex; chosen(v) => { if root.apply-color(v) { root.value = v; root.valid = true; color-picker.close(); } } }
                    CursorPaletteSwatch { hex: "#E040FB"; swatch-color: #E040FB; selected: root.value == self.hex; chosen(v) => { if root.apply-color(v) { root.value = v; root.valid = true; color-picker.close(); } } }
                }
                HorizontalLayout {
                    spacing: 6px;
                    CursorPaletteSwatch { hex: "#F48FB1"; swatch-color: #F48FB1; selected: root.value == self.hex; chosen(v) => { if root.apply-color(v) { root.value = v; root.valid = true; color-picker.close(); } } }
                    CursorPaletteSwatch { hex: "#FF8A65"; swatch-color: #FF8A65; selected: root.value == self.hex; chosen(v) => { if root.apply-color(v) { root.value = v; root.valid = true; color-picker.close(); } } }
                    CursorPaletteSwatch { hex: "#FFF176"; swatch-color: #FFF176; selected: root.value == self.hex; chosen(v) => { if root.apply-color(v) { root.value = v; root.valid = true; color-picker.close(); } } }
                    CursorPaletteSwatch { hex: "#A5D6A7"; swatch-color: #A5D6A7; selected: root.value == self.hex; chosen(v) => { if root.apply-color(v) { root.value = v; root.valid = true; color-picker.close(); } } }
                    CursorPaletteSwatch { hex: "#80CBC4"; swatch-color: #80CBC4; selected: root.value == self.hex; chosen(v) => { if root.apply-color(v) { root.value = v; root.valid = true; color-picker.close(); } } }
                    CursorPaletteSwatch { hex: "#90CAF9"; swatch-color: #90CAF9; selected: root.value == self.hex; chosen(v) => { if root.apply-color(v) { root.value = v; root.valid = true; color-picker.close(); } } }
                }
                HorizontalLayout {
                    spacing: 6px;
                    CursorPaletteSwatch { hex: "#B39DDB"; swatch-color: #B39DDB; selected: root.value == self.hex; chosen(v) => { if root.apply-color(v) { root.value = v; root.valid = true; color-picker.close(); } } }
                    CursorPaletteSwatch { hex: "#CE93D8"; swatch-color: #CE93D8; selected: root.value == self.hex; chosen(v) => { if root.apply-color(v) { root.value = v; root.valid = true; color-picker.close(); } } }
                    CursorPaletteSwatch { hex: "#BCAAA4"; swatch-color: #BCAAA4; selected: root.value == self.hex; chosen(v) => { if root.apply-color(v) { root.value = v; root.valid = true; color-picker.close(); } } }
                    CursorPaletteSwatch { hex: "#9E9E9E"; swatch-color: #9E9E9E; selected: root.value == self.hex; chosen(v) => { if root.apply-color(v) { root.value = v; root.valid = true; color-picker.close(); } } }
                    CursorPaletteSwatch { hex: "#607D8B"; swatch-color: #607D8B; selected: root.value == self.hex; chosen(v) => { if root.apply-color(v) { root.value = v; root.valid = true; color-picker.close(); } } }
                    CursorPaletteSwatch { hex: "#2D2D2F"; swatch-color: #2D2D2F; selected: root.value == self.hex; chosen(v) => { if root.apply-color(v) { root.value = v; root.valid = true; color-picker.close(); } } }
                }
            }
        }
    }
}

// A macOS-style wallpaper thumbnail: a rounded, clipped preview (passed via
// @children) with a selection ring + check badge. The label sits below it in
// the page, not inside.
component WallpaperSwatch inherits Rectangle {
    in property <bool> selected;
    callback clicked();
    width: 120px;
    height: 74px;
    border-radius: 8px;
    border-width: root.selected ? 3px : 1px;
    border-color: root.selected ? Theme.accent : Theme.border-strong;
    clip: true;
    @children
    if root.selected : Rectangle {
        x: parent.width - self.width - 5px;
        y: 5px;
        width: 18px;
        height: 18px;
        border-radius: 9px;
        background: Theme.accent;
        Text {
            text: "\u{E5CA}"; // check
            font-family: "Material Icons"; color: white; font-size: 13px * Theme.panel-font;
            width: 100%; height: 100%;
            horizontal-alignment: center; vertical-alignment: center;
        }
    }
    ta := TouchArea {
        mouse-cursor: pointer;
        clicked => { root.clicked(); }
    }
}

// The settings content (nav + pages). Embedded in AppWindow's modal overlay.
export component InterfacePanel inherits Rectangle {
    in property <bool> lang-en;
    in property <[string]> term-fonts;
    in property <string> term-font-family;
    in property <length> term-font-size;
    in-out property <bool> term-font-bold;
    in-out property <string> term-cursor-style: "block";
    in-out property <string> term-cursor-color-hex: "#D4D4D4";
    in property <color> term-cursor-color: #D4D4D4;
    in-out property <bool> output-highlight-enabled;
    in-out property <string> output-highlight-preset;
    in property <[OutputRuleItem]> output-highlight-rules;
    in-out property <string> output-highlight-rule-status;
    in property <float> ui-scale;
    in-out property <bool> sftp-follow-cd;
    in-out property <bool> collapse-sidebar-default;
    in-out property <bool> collapse-sftp-default;
    in-out property <bool> sync-upload-enabled;
    in-out property <bool> webdav-enabled;
    in-out property <string> webdav-url;
    in-out property <string> webdav-username;
    in-out property <string> webdav-password;
    in-out property <string> webdav-remote-path;
    in-out property <bool> webdav-accept-invalid-certs;
    in-out property <string> webdav-status;
    in-out property <bool> download-always-ask;
    in-out property <bool> welcome-as-sidebar;
    in-out property <bool> update-check-enabled;
    in-out property <float> wallpaper-overlay;   // frosted-panel opacity 0.30-1.00
    // Active wallpaper id: "" / "builtin:light" / "builtin:dark" / a file path.
    in property <string> current-wallpaper;
    in property <string> custom-wallpaper-name;   // basename for the file row

    property <string> ifd-page: "font";
    property <string> new-rule-pattern;
    property <bool> new-rule-regex;
    property <bool> new-rule-case-sensitive;
    property <bool> new-rule-whole-line;
    property <string> new-rule-color: "red";
    property <bool> wp-is-custom:
        root.current-wallpaper != "" && root.current-wallpaper != "builtin:light"
        && root.current-wallpaper != "builtin:dark" && root.current-wallpaper != "builtin:tech"
        && root.current-wallpaper != "builtin:miku" && root.current-wallpaper != "builtin:ms";

    callback set-term-font(string);
    callback set-term-font-size(int);
    callback set-term-font-bold(bool);
    callback set-term-cursor-style(string);
    callback set-term-cursor-color(string) -> bool;
    callback set-output-highlight(bool, string);
    callback add-output-highlight-rule(string, bool, bool, bool, string) -> bool;
    callback remove-output-highlight-rule(int);
    callback set-output-highlight-rule-enabled(int, bool);
    callback set-ui-scale(int);
    callback set-panel-font(int);   // settings-panel font scale, percent
    callback set-sftp-follow-cd(bool);
    callback set-collapse-sidebar-default(bool);
    callback set-collapse-sftp-default(bool);
    callback set-sync-upload-enabled(bool);
    callback save-webdav-settings(bool, string, string, string, string, bool);
    callback webdav-upload();
    callback webdav-download();
    callback set-download-always-ask(bool);
    callback set-welcome-as-sidebar(bool);
    callback set-update-check-enabled(bool);   // startup new-version check (#184)
    callback persist-wallpaper-overlay(float);   // save the overlay opacity
    callback set-wallpaper(string);    // none / builtin selection
    callback pick-wallpaper-file();    // open the OS file dialog (Rust)

    HorizontalLayout {
        // --- Left nav ------------------------------------------------------
        Rectangle {
            width: 168px;
            // Transparent so the whole dialog is one frosted layer (the card's
            // bg-panel); a 1px divider keeps the nav/content separation (items 6/7).
            background: transparent;
            Rectangle {
                x: parent.width - 1px; width: 1px; height: parent.height;
                background: Theme.border-subtle;
            }
            VerticalLayout {
                padding: 10px;
                spacing: 2px;
                alignment: start;
                NavItem {
                    icon: "\u{E167}"; label: root.lang-en ? "Font" : "字体";
                    active: root.ifd-page == "font";
                    clicked => { root.ifd-page = "font"; }
                }
                NavItem {
                    icon: "\u{E8D4}"; label: root.lang-en ? "Output" : "输出高亮";
                    active: root.ifd-page == "output";
                    clicked => { root.ifd-page = "output"; }
                }
                NavItem {
                    icon: "\u{E1BC}"; label: root.lang-en ? "Wallpaper" : "壁纸";
                    active: root.ifd-page == "wallpaper";
                    clicked => { root.ifd-page = "wallpaper"; }
                }
                NavItem {
                    icon: "\u{E2C7}"; label: "SFTP";
                    active: root.ifd-page == "sftp";
                    clicked => { root.ifd-page = "sftp"; }
                }
                NavItem {
                    icon: "\u{E5CB}"; label: root.lang-en ? "Sidebars" : "侧栏";
                    active: root.ifd-page == "sidebar";
                    clicked => { root.ifd-page = "sidebar"; }
                }
                NavItem {
                    icon: "\u{E88A}"; label: root.lang-en ? "Welcome page" : "欢迎页";
                    active: root.ifd-page == "welcome";
                    clicked => { root.ifd-page = "welcome"; }
                }
                NavItem {
                    icon: "\u{E627}"; label: root.lang-en ? "Session sync" : "会话同步";
                    active: root.ifd-page == "sync";
                    clicked => { root.ifd-page = "sync"; }
                }
                NavItem {
                    icon: "\u{E2C2}"; label: "WebDAV";
                    active: root.ifd-page == "webdav";
                    clicked => { root.ifd-page = "webdav"; }
                }
                NavItem {
                    icon: "\u{E2C4}"; label: root.lang-en ? "Download" : "下载";
                    active: root.ifd-page == "download";
                    clicked => { root.ifd-page = "download"; }
                }
                NavItem {
                    icon: "\u{E923}"; label: root.lang-en ? "Update check" : "新版本提示";
                    active: root.ifd-page == "update";
                    clicked => { root.ifd-page = "update"; }
                }
            }
        }
        // --- Right content -------------------------------------------------
        Rectangle {
            horizontal-stretch: 1;
            // Transparent: the card's single bg-panel frost shows through, so the
            // settings panel matches the welcome/resource panels and tracks the
            // wallpaper-opacity slider (items 6/7).
            background: transparent;

            settings-scroll := ScrollView {
                width: 100%;
                height: 100%;
                viewport-width: self.visible-width;
                viewport-height: max(self.visible-height, settings-pages.preferred-height);

                settings-pages := VerticalLayout {
                    width: settings-scroll.visible-width;

            // --- Font page ---------------------------------------------
            if root.ifd-page == "font" : VerticalLayout {
                padding-left: 20px;
                padding-right: 20px;
                padding-top: 14px;
                spacing: 0;
                alignment: start;

                SectionHeader { text: root.lang-en ? "FONT" : "字体"; height: 24px; }
                SettingRow {
                    label: root.lang-en ? "Terminal font" : "终端字体";
                    ComboBox {
                        width: 220px;
                        model: root.term-fonts;
                        current-value: root.term-font-family;
                        selected(v) => { root.set-term-font(v); }
                    }
                }
                SettingRow {
                    label: root.lang-en ? "Terminal font size" : "终端字体大小";
                    Stepper {
                        value: root.term-font-size / 1px; minimum: 8; maximum: 32; step: 1; unit: "px";
                        changed(v) => { root.set-term-font-size(v); }
                    }
                }
                SettingRow {
                    label: root.lang-en ? "Bold terminal text" : "终端字体加粗";
                    desc: root.lang-en ? "Makes regular terminal output use a bold face."
                                       : "让普通终端输出使用加粗字重。";
                    Switch {
                        on: root.term-font-bold;
                        toggled(v) => { root.term-font-bold = v; root.set-term-font-bold(v); }
                    }
                }
                SettingRow {
                    label: root.lang-en ? "Cursor shape" : "光标类型";
                    desc: root.lang-en ? "Choose the terminal insertion cursor shape."
                                       : "选择终端输入光标的形状。";
                    HorizontalLayout {
                        spacing: 5px;
                        CursorStyleButton {
                            label: root.lang-en ? "Block" : "块状";
                            cursor-kind: "block";
                            selected: root.term-cursor-style == "block";
                            clicked => { root.term-cursor-style = "block"; root.set-term-cursor-style("block"); }
                        }
                        CursorStyleButton {
                            label: root.lang-en ? "Bar" : "竖线";
                            cursor-kind: "bar";
                            selected: root.term-cursor-style == "bar";
                            clicked => { root.term-cursor-style = "bar"; root.set-term-cursor-style("bar"); }
                        }
                        CursorStyleButton {
                            label: root.lang-en ? "Line" : "下划线";
                            cursor-kind: "underline";
                            selected: root.term-cursor-style == "underline";
                            clicked => { root.term-cursor-style = "underline"; root.set-term-cursor-style("underline"); }
                        }
                    }
                }
                SettingRow {
                    label: root.lang-en ? "Cursor color" : "光标颜色";
                    desc: root.lang-en ? "Enter a hexadecimal RGB color."
                                       : "输入十六进制 RGB 颜色。";
                    CursorColorInput {
                        value <=> root.term-cursor-color-hex;
                        preview-color: root.term-cursor-color;
                        apply-color(v) => { root.set-term-cursor-color(v) }
                    }
                }
                SettingRow {
                    label: root.lang-en ? "UI scale" : "界面缩放";
                    desc: root.lang-en ? "Zooms the whole interface (not this panel)."
                                       : "缩放整个界面(不影响本面板)。";
                    Stepper {
                        value: round(root.ui-scale * 100); minimum: 80; maximum: 200; step: 10; unit: "%";
                        changed(v) => { root.set-ui-scale(v); }
                    }
                }
                SettingRow {
                    label: root.lang-en ? "Settings font size" : "界面字体大小";
                    desc: root.lang-en ? "Enlarges this settings panel (font + window)."
                                       : "放大本设置面板的字体和窗口。";
                    show-divider: false;
                    Stepper {
                        value: round(Theme.panel-font * 100); minimum: 80; maximum: 160; step: 10; unit: "%";
                        changed(v) => { root.set-panel-font(v); }
                    }
                }

                Rectangle { height: 14px; }
                SectionHeader { text: root.lang-en ? "PREVIEW" : "预览"; height: 22px; }
                Rectangle {
                    height: 52px;
                    background: Theme.term-bg;
                    border-radius: 6px;
                    border-width: 1px;
                    border-color: Theme.border-subtle;
                    Text {
                        x: 12px;
                        text: "meatshell ~$ echo preview 0123";
                        font-family: Theme.term-font-family;
                        font-size: Theme.term-font-size;
                        font-weight: Theme.term-font-bold ? 700 : 400;
                        color: Theme.term-fg;
                        vertical-alignment: center;
                        height: parent.height;
                    }
                }
            }

            // --- Output highlighting page -----------------------------
            if root.ifd-page == "output" : VerticalLayout {
                padding-left: 20px;
                padding-right: 20px;
                padding-top: 14px;
                spacing: 0;
                alignment: start;

                SectionHeader { text: root.lang-en ? "OUTPUT HIGHLIGHTING" : "输出高亮"; height: 24px; }
                SettingRow {
                    label: root.lang-en ? "Highlight plain terminal output" : "高亮纯文本终端输出";
                    desc: root.lang-en
                        ? "Adds client-side colours only when the program did not provide ANSI styling."
                        : "仅在程序未提供 ANSI 样式时由客户端补充颜色。";
                    Switch {
                        on: root.output-highlight-enabled;
                        toggled(v) => {
                            root.output-highlight-enabled = v;
                            root.set-output-highlight(v, root.output-highlight-preset);
                        }
                    }
                }
                SettingRow {
                    label: root.lang-en ? "Built-in rule set" : "内置规则集";
                    desc: root.lang-en
                        ? "Log levels is conservative; DevOps also recognises deployment and health states."
                        : "日志级别更保守；DevOps 还识别部署与健康状态。";
                    show-divider: false;
                    ComboBox {
                        width: 190px;
                        enabled: root.output-highlight-enabled;
                        model: [root.lang-en ? "Log levels" : "日志级别", "DevOps"];
                        current-value: root.output-highlight-preset == "devops"
                            ? "DevOps"
                            : (root.lang-en ? "Log levels" : "日志级别");
                        selected(v) => {
                            root.output-highlight-preset = v == "DevOps" ? "devops" : "log";
                            root.set-output-highlight(
                                root.output-highlight-enabled,
                                root.output-highlight-preset);
                        }
                    }
                }

                Rectangle { height: 18px; }
                SectionHeader { text: root.lang-en ? "PREVIEW" : "预览"; height: 22px; }
                Rectangle {
                    height: root.output-highlight-preset == "devops" ? 116px : 92px;
                    background: Theme.term-bg;
                    border-radius: 6px;
                    border-width: 1px;
                    border-color: Theme.border-subtle;
                    VerticalLayout {
                        padding: 12px;
                        spacing: 5px;
                        Text { text: "DEBUG cache lookup"; color: root.output-highlight-enabled ? Theme.text-muted : Theme.term-fg; font-family: Theme.term-font-family; font-size: 12px; }
                        Text { text: "INFO server ready"; color: root.output-highlight-enabled ? Theme.accent : Theme.term-fg; font-family: Theme.term-font-family; font-size: 12px; }
                        Text { text: "WARN disk nearly full"; color: root.output-highlight-enabled ? Theme.warning : Theme.term-fg; font-family: Theme.term-font-family; font-size: 12px; }
                        Text { text: "ERROR connection failed"; color: root.output-highlight-enabled ? Theme.danger : Theme.term-fg; font-family: Theme.term-font-family; font-size: 12px; }
                        if root.output-highlight-preset == "devops" : Text { text: "SUCCESS deployment completed"; color: root.output-highlight-enabled ? Theme.success : Theme.term-fg; font-family: Theme.term-font-family; font-size: 12px; }
                    }
                }

                Rectangle { height: 18px; }
                SectionHeader { text: root.lang-en ? "CUSTOM RULES" : "自定义规则"; height: 22px; }
                Text {
                    text: root.lang-en
                        ? "Custom rules run before the built-in preset and never overwrite ANSI colours."
                        : "自定义规则优先于内置规则，且不会覆盖程序输出的 ANSI 颜色。";
                    color: Theme.text-muted;
                    font-size: 11px * Theme.panel-font;
                    wrap: word-wrap;
                }
                Rectangle { height: 10px; }
                LabeledInput {
                    label: root.lang-en ? "Keyword or regular expression" : "关键词或正则表达式";
                    placeholder: root.new-rule-regex ? "timeout|connection refused" : "connection refused";
                    value <=> root.new-rule-pattern;
                    accepted => {
                        if root.add-output-highlight-rule(
                            root.new-rule-pattern, root.new-rule-regex,
                            root.new-rule-case-sensitive, root.new-rule-whole-line,
                            root.new-rule-color) {
                            root.new-rule-pattern = "";
                        }
                    }
                }
                Rectangle { height: 8px; }
                HorizontalLayout {
                    spacing: 8px;
                    ComboBox {
                        width: 130px;
                        model: [root.lang-en ? "Keyword" : "关键词", root.lang-en ? "Regex" : "正则"];
                        current-value: root.new-rule-regex
                            ? (root.lang-en ? "Regex" : "正则")
                            : (root.lang-en ? "Keyword" : "关键词");
                        selected(v) => {
                            root.new-rule-regex = v == "Regex" || v == "正则";
                        }
                    }
                    ComboBox {
                        width: 120px;
                        model: ["Red", "Yellow", "Green", "Cyan", "Magenta", "Gray"];
                        current-value: root.new-rule-color == "yellow" ? "Yellow"
                            : root.new-rule-color == "green" ? "Green"
                            : root.new-rule-color == "cyan" ? "Cyan"
                            : root.new-rule-color == "magenta" ? "Magenta"
                            : root.new-rule-color == "gray" ? "Gray" : "Red";
                        selected(v) => {
                            root.new-rule-color = v == "Yellow" ? "yellow"
                                : v == "Green" ? "green"
                                : v == "Cyan" ? "cyan"
                                : v == "Magenta" ? "magenta"
                                : v == "Gray" ? "gray" : "red";
                        }
                    }
                    Rectangle { horizontal-stretch: 1; }
                    PrimaryButton {
                        text: root.lang-en ? "Add rule" : "添加规则";
                        disabled: root.new-rule-pattern == "";
                        clicked => {
                            if root.add-output-highlight-rule(
                                root.new-rule-pattern, root.new-rule-regex,
                                root.new-rule-case-sensitive, root.new-rule-whole-line,
                                root.new-rule-color) {
                                root.new-rule-pattern = "";
                            }
                        }
                    }
                }
                SettingRow {
                    label: root.lang-en ? "Case sensitive" : "区分大小写";
                    Switch {
                        on: root.new-rule-case-sensitive;
                        toggled(v) => { root.new-rule-case-sensitive = v; }
                    }
                }
                SettingRow {
                    label: root.lang-en ? "Highlight whole line" : "高亮整行";
                    desc: root.lang-en
                        ? "Otherwise only matching text is coloured."
                        : "关闭时仅高亮匹配到的文字。";
                    show-divider: false;
                    Switch {
                        on: root.new-rule-whole-line;
                        toggled(v) => { root.new-rule-whole-line = v; }
                    }
                }
                if root.output-highlight-rule-status != "" : Text {
                    text: root.output-highlight-rule-status;
                    color: Theme.danger;
                    font-size: 11px * Theme.panel-font;
                    wrap: word-wrap;
                }

                if root.output-highlight-rules.length == 0 : Text {
                    text: root.lang-en ? "No custom rules yet." : "暂无自定义规则。";
                    color: Theme.text-muted;
                    font-size: 11px * Theme.panel-font;
                    height: 34px;
                    vertical-alignment: center;
                }
                for rule[index] in root.output-highlight-rules : Rectangle {
                    height: 44px;
                    Rectangle { y: 0px; width: 100%; height: 1px; background: Theme.border-subtle; }
                    HorizontalLayout {
                        spacing: 9px;
                        Rectangle {
                            width: 8px;
                            height: 8px;
                            border-radius: 4px;
                            background: rule.color == "yellow" ? Theme.warning
                                : rule.color == "green" ? Theme.success
                                : rule.color == "cyan" ? Theme.accent
                                : rule.color == "magenta" ? #d670d6
                                : rule.color == "gray" ? Theme.text-muted
                                : Theme.danger;
                            vertical-stretch: 0;
                        }
                        VerticalLayout {
                            horizontal-stretch: 1;
                            alignment: center;
                            spacing: 2px;
                            Text {
                                text: rule.pattern;
                                color: rule.enabled ? Theme.text-primary : Theme.text-muted;
                                font-family: Theme.term-font-family;
                                font-size: 12px * Theme.panel-font;
                                overflow: elide;
                            }
                            Text {
                                text: (rule.regex ? "Regex" : (root.lang-en ? "Keyword" : "关键词"))
                                    + (rule.case-sensitive ? " · Aa" : "")
                                    + (rule.whole-line ? (root.lang-en ? " · whole line" : " · 整行") : "");
                                color: Theme.text-muted;
                                font-size: 10px * Theme.panel-font;
                            }
                        }
                        Switch {
                            on: rule.enabled;
                            toggled(v) => { root.set-output-highlight-rule-enabled(index, v); }
                        }
                        Rectangle {
                            width: 28px;
                            height: 28px;
                            border-radius: 5px;
                            background: delete-ta.has-hover ? Theme.bg-hover : transparent;
                            delete-ta := TouchArea {
                                mouse-cursor: pointer;
                                clicked => { root.remove-output-highlight-rule(index); }
                            }
                            Text {
                                text: "\u{E872}";
                                font-family: "Material Icons";
                                color: Theme.text-muted;
                                font-size: 15px * Theme.panel-font;
                                width: 100%; height: 100%;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                    }
                }
            }

            // --- Wallpaper page ----------------------------------------
            if root.ifd-page == "wallpaper" : VerticalLayout {
                padding-left: 20px;
                padding-right: 20px;
                padding-top: 14px;
                spacing: 0;
                alignment: start;

                SectionHeader { text: root.lang-en ? "WALLPAPER" : "壁纸"; height: 24px; }
                Text {
                    text: root.lang-en
                        ? "Pick a wallpaper — the interface tints itself to match (accent, panels, light/dark)."
                        : "选一张壁纸,界面会沉浸式地适配它的颜色(强调色、面板、深浅)。";
                    color: Theme.text-muted; font-size: 11px * Theme.panel-font; wrap: word-wrap;
                }
                Rectangle { height: 12px; }

                // Built-in choices: keep this row horizontally scrollable as
                // bundled wallpapers grow.
                builtin-wallpapers-scroll := ScrollView {
                    height: 106px;
                    width: 100%;
                    viewport-width: max(self.visible-width, builtin-wallpapers-row.preferred-width);
                    viewport-height: self.visible-height;

                    builtin-wallpapers-row := HorizontalLayout {
                        spacing: 11px;
                        alignment: start;
                    VerticalLayout {
                        spacing: 5px;
                        WallpaperSwatch {
                            width: 100px;
                            selected: root.current-wallpaper == "";
                            clicked => { root.set-wallpaper(""); }
                            Rectangle {
                                width: 100%; height: 100%;
                                background: Theme.window-base;
                                Text {
                                    text: "\u{E14C}"; // clear / none
                                    font-family: "Material Icons"; color: Theme.text-muted;
                                    font-size: 22px * Theme.panel-font;
                                    width: 100%; height: 100%;
                                    horizontal-alignment: center; vertical-alignment: center;
                                }
                            }
                        }
                        Text { text: root.lang-en ? "None" : "无"; font-size: 11px * Theme.panel-font;
                               color: Theme.text-secondary; horizontal-alignment: center; }
                    }
                    VerticalLayout {
                        spacing: 5px;
                        WallpaperSwatch {
                            width: 100px;
                            selected: root.current-wallpaper == "builtin:light";
                            clicked => { root.set-wallpaper("builtin:light"); }
                            Rectangle {
                                width: 100%; height: 100%;
                                background: @linear-gradient(135deg, #eff3fb 0%, #d5e1f2 100%);
                                Rectangle {
                                    x: parent.width * 0.66; y: -parent.height * 0.2;
                                    width: 56px; height: 56px; border-radius: 28px;
                                    background: #4a90e2; opacity: 0.30;
                                }
                            }
                        }
                        Text { text: root.lang-en ? "Meat Light" : "简约·浅"; font-size: 11px * Theme.panel-font;
                               color: Theme.text-secondary; horizontal-alignment: center; }
                    }
                    VerticalLayout {
                        spacing: 5px;
                        WallpaperSwatch {
                            width: 100px;
                            selected: root.current-wallpaper == "builtin:dark";
                            clicked => { root.set-wallpaper("builtin:dark"); }
                            Rectangle {
                                width: 100%; height: 100%;
                                background: @linear-gradient(135deg, #10131a 0%, #1b2233 100%);
                                Rectangle {
                                    x: parent.width * 0.66; y: -parent.height * 0.2;
                                    width: 56px; height: 56px; border-radius: 28px;
                                    background: #4a6ce0; opacity: 0.40;
                                }
                            }
                        }
                        Text { text: root.lang-en ? "Meat Dark" : "简约·暗"; font-size: 11px * Theme.panel-font;
                               color: Theme.text-secondary; horizontal-alignment: center; }
                    }
                    VerticalLayout {
                        spacing: 5px;
                        WallpaperSwatch {
                            width: 100px;
                            selected: root.current-wallpaper == "builtin:tech";
                            clicked => { root.set-wallpaper("builtin:tech"); }
                            Rectangle {
                                width: 100%; height: 100%;
                                background: @linear-gradient(180deg, #05060f 0%, #0b1430 55%, #1a0a2e 100%);
                                clip: true;
                                // glowing planet
                                Rectangle {
                                    x: parent.width * 0.5 - 16px; y: parent.height * 0.22;
                                    width: 32px; height: 32px; border-radius: 16px;
                                    background: @radial-gradient(circle, #ff5ea8 0%, #ff5ea800 70%);
                                }
                                // neon horizon line
                                Rectangle {
                                    y: parent.height * 0.58; width: parent.width; height: 2px;
                                    background: #19e6ff; opacity: 0.85;
                                }
                            }
                        }
                        Text { text: root.lang-en ? "Fantasy 3048" : "幻想3048"; font-size: 11px * Theme.panel-font;
                               color: Theme.text-secondary; horizontal-alignment: center; }
                    }
                    VerticalLayout {
                        spacing: 5px;
                        WallpaperSwatch {
                            width: 100px;
                            selected: root.current-wallpaper == "builtin:ms";
                            clicked => { root.set-wallpaper("builtin:ms"); }
                            Image {
                                width: 100%; height: 100%;
                                source: @image-url("../assets/ms.jpg");
                                image-fit: cover;
                            }
                        }
                        Text { text: "MS"; font-size: 11px * Theme.panel-font;
                               color: Theme.text-secondary; horizontal-alignment: center; }
                    }
                    VerticalLayout {
                        spacing: 5px;
                        WallpaperSwatch {
                            width: 100px;
                            selected: root.current-wallpaper == "builtin:miku";
                            clicked => { root.set-wallpaper("builtin:miku"); }
                            Image {
                                width: 100%; height: 100%;
                                source: @image-url("../assets/miku.jpg");
                                image-fit: cover;
                            }
                        }
                        Text { text: "Miku"; font-size: 11px * Theme.panel-font;
                               color: Theme.text-secondary; horizontal-alignment: center; }
                    }
                    }
                }

                Rectangle { height: 16px; }
                SectionHeader { text: root.lang-en ? "CUSTOM" : "自定义"; height: 22px; }
                HorizontalLayout {
                    spacing: 14px;
                    alignment: start;
                    WallpaperSwatch {
                        selected: root.wp-is-custom;
                        clicked => { root.pick-wallpaper-file(); }
                        // Show the real image when a custom one is active, else a
                        // "choose a file" placeholder.
                        if root.wp-is-custom : Image {
                            width: 100%; height: 100%;
                            source: Theme.wallpaper;
                            image-fit: cover;
                        }
                        if !root.wp-is-custom : Rectangle {
                            width: 100%; height: 100%;
                            background: Theme.bg-elevated;
                            Text {
                                text: "\u{E2C6}"; // folder-open
                                font-family: "Material Icons"; color: Theme.text-secondary;
                                font-size: 22px * Theme.panel-font;
                                width: 100%; height: 100%;
                                horizontal-alignment: center; vertical-alignment: center;
                            }
                        }
                    }
                    VerticalLayout {
                        alignment: center;
                        spacing: 6px;
                        Rectangle {
                            width: 130px; height: 30px;
                            border-radius: 6px;
                            background: pick-ta.has-hover ? Theme.accent-hover : Theme.accent;
                            pick-ta := TouchArea {
                                mouse-cursor: pointer;
                                clicked => { root.pick-wallpaper-file(); }
                            }
                            Text {
                                text: root.lang-en ? "Choose file…" : "选择文件…";
                                color: white; font-size: 12px * Theme.panel-font;
                                width: 100%; height: 100%;
                                horizontal-alignment: center; vertical-alignment: center;
                            }
                        }
                        if root.wp-is-custom : Text {
                            text: root.custom-wallpaper-name;
                            color: Theme.text-muted; font-size: 11px * Theme.panel-font;
                            width: 150px; overflow: elide;
                        }
                    }
                }

                Rectangle { height: 16px; }
                SectionHeader { text: root.lang-en ? "OVERLAY" : "遮罩"; height: 22px; }
                SettingRow {
                    label: root.lang-en ? "Wallpaper transparency" : "壁纸遮罩透明度";
                    desc: root.lang-en
                        ? "How much the wallpaper shows through panels and the terminal (no effect without a wallpaper)."
                        : "壁纸透过面板 / 终端背景的程度,越往右越透;没设壁纸时不生效。";
                    show-divider: false;
                    HorizontalLayout {
                        spacing: 8px;
                        Slider {
                            width: 150px;
                            minimum: 0;
                            // Up to 70% transparency (overlay floor 0.30).
                            maximum: 70;
                            value: (1.0 - root.wallpaper-overlay) * 100;
                            changed(v) => { root.wallpaper-overlay = 1.0 - v / 100; }
                            released(v) => { root.persist-wallpaper-overlay(1.0 - v / 100); }
                        }
                        Text {
                            text: "\{round((1.0 - root.wallpaper-overlay) * 100)}%";
                            color: Theme.text-secondary;
                            font-size: 12px * Theme.panel-font;
                            vertical-alignment: center;
                            width: 34px;
                        }
                    }
                }
            }

            // --- SFTP page ---------------------------------------------
            if root.ifd-page == "sftp" : VerticalLayout {
                padding-left: 20px;
                padding-right: 20px;
                padding-top: 14px;
                spacing: 0;
                alignment: start;
                SectionHeader { text: "SFTP"; height: 24px; }
                SettingRow {
                    label: root.lang-en ? "SFTP follows terminal cd" : "SFTP 跟随 cd 更新";
                    desc: root.lang-en
                        ? "A cd in the terminal switches the SFTP panel to the same directory."
                        : "终端里执行 cd 时,SFTP 面板自动切到相同目录。";
                    show-divider: false;
                    Switch {
                        on: root.sftp-follow-cd;
                        toggled(v) => { root.sftp-follow-cd = v; root.set-sftp-follow-cd(v); }
                    }
                }
            }

            // --- Sidebars page -----------------------------------------
            if root.ifd-page == "sidebar" : VerticalLayout {
                padding-left: 20px;
                padding-right: 20px;
                padding-top: 14px;
                spacing: 0;
                alignment: start;
                SectionHeader { text: root.lang-en ? "SIDEBARS" : "侧栏"; height: 24px; }
                SettingRow {
                    label: root.lang-en ? "Collapse the resource panel by default" : "默认收起资源视图面板";
                    Switch {
                        on: root.collapse-sidebar-default;
                        toggled(v) => { root.collapse-sidebar-default = v; root.set-collapse-sidebar-default(v); }
                    }
                }
                SettingRow {
                    label: root.lang-en ? "Collapse the SFTP panel by default" : "默认收起 SFTP 侧栏";
                    desc: root.lang-en
                        ? "Takes effect on next launch; handy on low-spec jump hosts."
                        : "下次启动生效;低配跳板机上可减少常驻面板开销。";
                    show-divider: false;
                    Switch {
                        on: root.collapse-sftp-default;
                        toggled(v) => { root.collapse-sftp-default = v; root.set-collapse-sftp-default(v); }
                    }
                }
            }

            // --- Welcome page ------------------------------------------
            if root.ifd-page == "welcome" : VerticalLayout {
                padding-left: 20px;
                padding-right: 20px;
                padding-top: 14px;
                spacing: 0;
                alignment: start;
                SectionHeader { text: root.lang-en ? "WELCOME PAGE" : "欢迎页"; height: 24px; }
                SettingRow {
                    label: root.lang-en ? "Show the welcome page as a sidebar" : "欢迎页设为侧栏";
                    desc: root.lang-en
                        ? "Dock the session list on the left instead of a \"New tab\" tab; opened sessions fill the center."
                        : "把会话列表停靠在左侧,不再用「新标签页」标签;打开的会话占据中央区域。";
                    show-divider: false;
                    Switch {
                        on: root.welcome-as-sidebar;
                        toggled(v) => { root.welcome-as-sidebar = v; root.set-welcome-as-sidebar(v); }
                    }
                }
            }

            // --- Session sync page -------------------------------------
            if root.ifd-page == "sync" : VerticalLayout {
                padding-left: 20px;
                padding-right: 20px;
                padding-top: 14px;
                spacing: 0;
                alignment: start;
                SectionHeader { text: root.lang-en ? "SESSION SYNC" : "会话同步"; height: 24px; }
                SettingRow {
                    label: root.lang-en ? "Sync file uploads" : "文件上传同步";
                    desc: root.lang-en
                        ? "While session sync is on, an upload goes to the same path on each session; if missing, to that session's current SFTP directory."
                        : "会话同步开启时,上传会发往各会话的相同路径;路径不存在则发往该会话当前 SFTP 目录。";
                    show-divider: false;
                    Switch {
                        on: root.sync-upload-enabled;
                        toggled(v) => { root.sync-upload-enabled = v; root.set-sync-upload-enabled(v); }
                    }
                }
                Rectangle { height: 6px; }
                Text {
                    text: root.lang-en
                        ? "Session sync itself is toggled from the sync icon in the top-right bar."
                        : "会话同步本身从右上角的同步图标开关。";
                    color: Theme.text-muted; font-size: 11px * Theme.panel-font; wrap: word-wrap;
                }
            }

            // --- WebDAV page (#185) ------------------------------------
            if root.ifd-page == "webdav" : VerticalLayout {
                padding-left: 20px;
                padding-right: 20px;
                padding-top: 14px;
                spacing: 10px;
                alignment: start;
                SectionHeader { text: "WEBDAV"; height: 24px; }
                SettingRow {
                    label: root.lang-en ? "Enable WebDAV sync" : "启用 WebDAV 同步";
                    desc: root.lang-en
                        ? "Manual upload/download only; meatshell will not connect on startup."
                        : "仅手动上传/下载;meatshell 启动时不会自动连接。";
                    show-divider: false;
                    Switch {
                        on: root.webdav-enabled;
                        toggled(v) => { root.webdav-enabled = v; }
                    }
                }
                LabeledInput {
                    label: root.lang-en ? "Endpoint URL" : "WebDAV 地址";
                    placeholder: "https://nas:5006/all/ or https://nas:5006/all/meatshell-connections.json";
                    value <=> root.webdav-url;
                }
                LabeledInput {
                    label: root.lang-en ? "Username" : "用户名";
                    placeholder: root.lang-en ? "Optional" : "可选";
                    value <=> root.webdav-username;
                }
                LabeledInput {
                    label: root.lang-en ? "Password / app token" : "密码 / 应用令牌";
                    placeholder: root.lang-en ? "Optional" : "可选";
                    password: true;
                    value <=> root.webdav-password;
                }
                LabeledInput {
                    label: root.lang-en ? "Remote file" : "远端文件";
                    placeholder: "meatshell-connections.json";
                    value <=> root.webdav-remote-path;
                }
                SettingRow {
                    label: root.lang-en ? "Trust self-signed / intranet certs" : "信任自签名/内网证书";
                    desc: root.lang-en
                        ? "Use only for trusted NAS or LAN WebDAV over HTTPS."
                        : "仅用于可信 NAS 或局域网 HTTPS WebDAV。";
                    show-divider: false;
                    Switch {
                        on: root.webdav-accept-invalid-certs;
                        toggled(v) => { root.webdav-accept-invalid-certs = v; }
                    }
                }
                HorizontalLayout {
                    spacing: 8px;
                    alignment: end;
                    GhostButton {
                        text: root.lang-en ? "Save" : "保存";
                        clicked => {
                            root.save-webdav-settings(
                                root.webdav-enabled, root.webdav-url, root.webdav-username,
                                root.webdav-password, root.webdav-remote-path,
                                root.webdav-accept-invalid-certs);
                        }
                    }
                    GhostButton {
                        text: root.lang-en ? "Download" : "下载";
                        clicked => { root.webdav-download(); }
                    }
                    PrimaryButton {
                        text: root.lang-en ? "Upload" : "上传";
                        clicked => { root.webdav-upload(); }
                    }
                }
                Text {
                    text: root.webdav-status;
                    color: Theme.text-muted;
                    font-size: 11px * Theme.panel-font;
                    wrap: word-wrap;
                }
            }

            // --- Download page -----------------------------------------
            if root.ifd-page == "download" : VerticalLayout {
                padding-left: 20px;
                padding-right: 20px;
                padding-top: 14px;
                spacing: 0;
                alignment: start;
                SectionHeader { text: root.lang-en ? "DOWNLOAD" : "下载"; height: 24px; }
                SettingRow {
                    label: root.lang-en ? "Always ask where to save" : "总是询问保存去何处";
                    desc: root.lang-en
                        ? "Every download prompts for a location instead of using the preset folder."
                        : "每次下载都询问保存位置,而不是直接存到预设下载目录。";
                    show-divider: false;
                    Switch {
                        on: root.download-always-ask;
                        toggled(v) => { root.download-always-ask = v; root.set-download-always-ask(v); }
                    }
                }
            }

            // --- Update check page (#184) ------------------------------
            if root.ifd-page == "update" : VerticalLayout {
                padding-left: 20px;
                padding-right: 20px;
                padding-top: 14px;
                spacing: 0;
                alignment: start;
                SectionHeader { text: root.lang-en ? "UPDATE CHECK" : "新版本提示"; height: 24px; }
                SettingRow {
                    label: root.lang-en ? "Check for new versions on startup" : "启动时检查新版本";
                    desc: root.lang-en
                        ? "Off: meatshell no longer queries GitHub for releases and the update banner won't appear (takes effect next launch)."
                        : "关闭后:不再向 GitHub 查询新版本,也不会弹出更新提示(下次启动生效)。";
                    show-divider: false;
                    Switch {
                        on: root.update-check-enabled;
                        toggled(v) => { root.update-check-enabled = v; root.set-update-check-enabled(v); }
                    }
                }
            }

                }
            }
        }
    }
}
