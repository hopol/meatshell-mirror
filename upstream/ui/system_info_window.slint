// Detachable system-information window.
//
// Opens from the resource summary in the sidebar and shares live resource
// models with AppWindow, much like ProcWindow shares the process table.

import { Theme } from "theme.slint";
import { DiskInfo } from "sidebar.slint";

export struct SysMetricRow {
    label: string,
    percent: float,
    detail: string,
    kind: int, // 0 CPU / 1 memory / 2 swap
}

export struct SysNetRow {
    name: string,
    up: string,
    down: string,
}

export struct SysInfoRow {
    c1: string,
    c2: string,
    c3: string,
    c4: string,
    c5: string,
}

component InfoCard inherits Rectangle {
    in property <string> title;
    border-radius: Theme.radius-md;
    border-width: 1px;
    border-color: Theme.border-subtle;
    background: Theme.bg-panel.with-alpha(0.88);
    clip: true;
}

component CellText inherits Text {
    in property <bool> muted: false;
    color: root.muted ? Theme.text-muted : Theme.text-primary;
    font-size: Theme.fs-xs;
    font-family: Theme.font-mono;
    overflow: elide;
    horizontal-alignment: center;
    vertical-alignment: center;
}

component CellBox inherits Rectangle {
    in property <string> text;
    in property <bool> muted: false;
    in property <float> weight: 1.0;
    horizontal-stretch: root.weight;
    clip: true;

    CellText {
        text: root.text;
        muted: root.muted;
        width: parent.width;
        height: parent.height;
    }
}

component PairGrid inherits InfoCard {
    in property <[SysInfoRow]> rows;
    min-height: 188px;

    VerticalLayout {
        spacing: 0;
        Rectangle {
            height: 42px;
            background: Theme.bg-elevated.with-alpha(0.48);
            Text {
                text: root.title;
                color: Theme.text-primary;
                font-size: Theme.fs-sm;
                font-weight: 800;
                x: 14px;
                vertical-alignment: center;
            }
        }
        VerticalLayout {
            padding: 14px;
            spacing: 0;
            if root.rows.length == 0 : Rectangle {
                height: 34px;
                Text {
                    text: @tr("No data");
                    color: Theme.text-muted;
                    font-size: Theme.fs-xs;
                    vertical-alignment: center;
                }
            }
            for r in root.rows : Rectangle {
                height: 34px;
                Rectangle {
                    x: 0;
                    y: parent.height - 1px;
                    width: parent.width;
                    height: 1px;
                    background: Theme.border-subtle.with-alpha(0.65);
                }
                HorizontalLayout {
                    spacing: 12px;
                        CellBox { text: r.c1; muted: true; weight: 0.12; }
                        CellBox { text: r.c2; weight: 0.38; }
                        CellBox { text: r.c3; muted: true; weight: 0.12; }
                        CellBox { text: r.c4; weight: 0.38; }
                }
            }
        }
    }
}

component TableCard inherits InfoCard {
    in property <[SysInfoRow]> rows;
    in property <string> h1;
    in property <string> h2;
    in property <string> h3;
    in property <string> h4;
    in property <string> h5;
    in property <float> c1w: 0.2;
    in property <float> c2w: 0.2;
    in property <float> c3w: 0.2;
    in property <float> c4w: 0.2;
    in property <float> c5w: 0.2;
    min-height: 106px;

    VerticalLayout {
        spacing: 0;
        Rectangle {
            height: 42px;
            background: Theme.bg-elevated.with-alpha(0.48);
            Text {
                text: root.title;
                color: Theme.text-primary;
                font-size: Theme.fs-sm;
                font-weight: 800;
                x: 14px;
                vertical-alignment: center;
            }
        }
        Rectangle {
            height: 30px;
            background: Theme.bg-root.with-alpha(0.28);
            HorizontalLayout {
                padding-left: 14px;
                padding-right: 14px;
                spacing: 12px;
                CellBox { text: root.h1; muted: true; weight: root.c1w; }
                CellBox { text: root.h2; muted: true; weight: root.c2w; }
                CellBox { text: root.h3; muted: true; weight: root.c3w; }
                CellBox { text: root.h4; muted: true; weight: root.c4w; }
                if root.c5w > 0.0 : CellBox { text: root.h5; muted: true; weight: root.c5w; }
            }
        }
        if root.rows.length == 0 : Rectangle {
            height: 36px;
            Text {
                text: @tr("No data");
                color: Theme.text-muted;
                font-size: Theme.fs-xs;
                x: 14px;
                vertical-alignment: center;
            }
        }
        for r in root.rows : Rectangle {
            height: 34px;
            background: row-ta.has-hover ? Theme.bg-hover : transparent;
            Rectangle {
                width: parent.width;
                height: 1px;
                background: Theme.border-subtle.with-alpha(0.48);
            }
            row-ta := TouchArea {}
            HorizontalLayout {
                padding-left: 14px;
                padding-right: 14px;
                spacing: 12px;
                CellBox { text: r.c1; weight: root.c1w; }
                CellBox { text: r.c2; weight: root.c2w; }
                CellBox { text: r.c3; weight: root.c3w; }
                CellBox { text: r.c4; weight: root.c4w; }
                if root.c5w > 0.0 : CellBox { text: r.c5; weight: root.c5w; }
            }
        }
    }
}

export component SystemInfoWindow inherits Window {
    title: "meatshell - " + @tr("System information");
    icon: @image-url("../assets/icon.png");
    in-out property <bool> dark-mode <=> Theme.dark;
    in-out property <float> ui-scale <=> Theme.ui-scale;
    in-out property <string> ui-font-family <=> Theme.ui-font-family;
    in-out property <image> wallpaper-img <=> Theme.wallpaper;
    in-out property <bool> wallpaper-active <=> Theme.wallpaper-active;
    in-out property <color> wp-accent <=> Theme.wp-accent;
    in-out property <color> wp-tint <=> Theme.wp-tint;
    default-font-family: Theme.ui-font-family;

    in property <bool> custom-titlebar;
    no-frame: root.custom-titlebar;
    in property <string> host;
    in property <string> resource-title;
    in property <string> connection-state;
    in property <[SysMetricRow]> metrics;
    in property <[SysNetRow]> nets;
    in property <[DiskInfo]> disks;
    in property <[SysInfoRow]> overview-rows;
    in property <[SysInfoRow]> cpu-info-rows;
    in property <[SysInfoRow]> gpu-info-rows;
    in property <[SysInfoRow]> cpu-usage-rows;
    in property <[SysInfoRow]> memory-rows;
    in property <[SysInfoRow]> swap-rows;
    in property <[SysInfoRow]> network-rows;
    in property <[SysInfoRow]> filesystem-rows;

    callback close();
    callback win-drag();
    callback win-resize-se();

    min-width: 760px;
    min-height: 520px;
    preferred-width: 1160px;
    preferred-height: 760px;
    background: Theme.window-base;

    if Theme.wallpaper-active : Image {
        width: parent.width;
        height: parent.height;
        source: Theme.wallpaper;
        image-fit: cover;
    }
    Rectangle { width: parent.width; height: parent.height; background: Theme.bg-root.with-alpha(0.92); }

    VerticalLayout {
        spacing: 0;

        if root.custom-titlebar : Rectangle {
            height: 36px;
            background: Theme.bg-elevated;
            tb-drag := TouchArea {
                pointer-event(e) => {
                    if (e.kind == PointerEventKind.down && e.button == PointerEventButton.left) {
                        root.win-drag();
                    }
                }
            }
            HorizontalLayout {
                padding-left: 12px;
                spacing: 8px;
                Image { source: @image-url("../assets/icon.png"); width: 16px; height: 16px; vertical-alignment: center; }
                Text {
                    text: @tr("System information") + (root.host != "" ? "  -  " + root.host : "");
                    color: Theme.text-secondary;
                    font-size: Theme.fs-sm;
                    vertical-alignment: center;
                }
                Rectangle { horizontal-stretch: 1; }
                Rectangle {
                    width: 46px;
                    background: close-ta.has-hover ? #e81123 : transparent;
                    close-ta := TouchArea { mouse-cursor: pointer; clicked => { root.close(); } }
                    Text {
                        text: "\u{E5CD}";
                        font-family: "Material Icons";
                        color: close-ta.has-hover ? white : Theme.text-secondary;
                        font-size: 16px;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
            }
        }

        Flickable {
            vertical-stretch: 1;
            viewport-width: self.width;
            viewport-height: max(self.height, content.preferred-height);

            content := VerticalLayout {
                padding: 14px;
                spacing: 14px;

                PairGrid {
                    title: @tr("Overview");
                    rows: root.overview-rows;
                }

                TableCard {
                    title: "CPU";
                    rows: root.cpu-info-rows;
                    h1: @tr("Name"); h2: @tr("Cores"); h3: @tr("Frequency"); h4: @tr("Cache"); h5: @tr("Vendor") + " / BogoMips";
                    c1w: 0.48; c2w: 0.10; c3w: 0.15; c4w: 0.16; c5w: 0.11;
                }

                TableCard {
                    title: "GPU";
                    rows: root.gpu-info-rows;
                    h1: @tr("Name"); h2: @tr("Vendor"); h3: @tr("Driver"); h4: @tr("Memory"); h5: "";
                    c1w: 0.32; c2w: 0.30; c3w: 0.20; c4w: 0.18; c5w: 0.0;
                }

                TableCard {
                    title: @tr("CPU usage");
                    rows: root.cpu-usage-rows;
                    h1: @tr("User"); h2: @tr("System"); h3: "Nice"; h4: @tr("Idle"); h5: "IO / IRQ / SoftIRQ / Steal";
                    c1w: 0.14; c2w: 0.14; c3w: 0.14; c4w: 0.14; c5w: 0.44;
                }

                HorizontalLayout {
                    spacing: 14px;
                    TableCard {
                        horizontal-stretch: 1;
                        title: @tr("Memory");
                        rows: root.memory-rows;
                        h1: @tr("Total"); h2: @tr("Used"); h3: @tr("Free"); h4: @tr("Usage"); h5: @tr("Cache");
                        c1w: 0.20; c2w: 0.20; c3w: 0.20; c4w: 0.20; c5w: 0.20;
                    }
                    TableCard {
                        horizontal-stretch: 1;
                        title: @tr("Swap");
                        rows: root.swap-rows;
                        h1: @tr("Total"); h2: @tr("Used"); h3: @tr("Free"); h4: @tr("Usage"); h5: "";
                        c1w: 0.25; c2w: 0.25; c3w: 0.25; c4w: 0.25; c5w: 0.0;
                    }
                }

                TableCard {
                    title: @tr("Network interfaces");
                    rows: root.network-rows;
                    h1: @tr("Name"); h2: @tr("Sent"); h3: @tr("Received"); h4: @tr("Send speed"); h5: @tr("Receive speed");
                    c1w: 0.18; c2w: 0.20; c3w: 0.20; c4w: 0.21; c5w: 0.21;
                }

                TableCard {
                    title: @tr("Filesystems");
                    rows: root.filesystem-rows;
                    h1: @tr("Name"); h2: @tr("Size"); h3: @tr("Used"); h4: @tr("Available"); h5: @tr("Mount point");
                    c1w: 0.38; c2w: 0.16; c3w: 0.12; c4w: 0.16; c5w: 0.18;
                }
            }
        }
    }

    if root.custom-titlebar : Rectangle {
        width: 16px; height: 16px;
        x: root.width - self.width;
        y: root.height - self.height;
        TouchArea {
            mouse-cursor: nwse-resize;
            pointer-event(e) => {
                if (e.kind == PointerEventKind.down && e.button == PointerEventButton.left) {
                    root.win-resize-se();
                }
            }
        }
        Rectangle { x: parent.width - 5px; y: parent.height - 5px; width: 2px; height: 2px; background: Theme.text-muted; }
        Rectangle { x: parent.width - 9px; y: parent.height - 5px; width: 2px; height: 2px; background: Theme.text-muted; }
        Rectangle { x: parent.width - 5px; y: parent.height - 9px; width: 2px; height: 2px; background: Theme.text-muted; }
    }
}
